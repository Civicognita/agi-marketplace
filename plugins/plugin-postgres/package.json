{
  "name": "@agi/plugin-postgres",
  "version": "0.2.3",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "aionima": {
    "id": "agi-postgres",
    "name": "PostgreSQL",
    "description": "PostgreSQL database service \u2014 required by the ID service for identity and credential storage",
    "category": "service",
    "provides": [
      "services",
      "runtimes",
      "stacks"
    ],
    "permissions": [
      "shell.exec",
      "network"
    ],
    "entry": "./src/index.ts",
    "aionimaVersion": ">=0.1.0",
    "bakedIn": true,
    "disableable": false,
    "aliases": [
      "aionima-postgres"
    ]
  },
  "dependencies": {
    "@agi/sdk": "workspace:*"
  }
}
